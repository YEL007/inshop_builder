# Copy this file to .env and fill in values before deploying.
# .env is git-ignored — never commit real credentials.

# Django secret key
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-secret-key-change-this

DEBUG=False

# PostgreSQL
DB_NAME=inshop
DB_USER=inshop
DB_PASSWORD=YourStrongDbPassword123!

# Django allowed hosts (comma-separated)
ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1

# CORS — your frontend origin in production
ALLOWED_ORIGIN=https://yourdomain.com

# Email (optional — for order confirmation emails)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@inshop-builder.com
