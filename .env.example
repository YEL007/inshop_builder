# Copy this file to .env and fill in strong values before deploying.
# .env is git-ignored — never commit real credentials.

# PostgreSQL password (used by both the db and odoo containers)
POSTGRES_PASSWORD=change_me_strong_db_password

# Odoo master password — protects the /web/database/ manager UI
ODOO_ADMIN_PASSWD=change_me_strong_admin_password

# Allowed CORS origin — your frontend domain in production
# Example: https://yourdomain.com
# During development: http://localhost:8080
ALLOWED_ORIGIN=http://localhost:8080
