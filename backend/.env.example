# Copy this to .env and fill in values before deploying.
# .env is git-ignored — never commit real credentials.

SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=False

# Database (PostgreSQL)
DB_NAME=inshop
DB_USER=inshop
DB_PASSWORD=YourStrongDbPassword123!
DB_HOST=db
DB_PORT=5432

# CORS — your frontend origin
ALLOWED_ORIGIN=https://yourdomain.com

# Django allowed hosts (comma-separated)
ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1

# Email (optional — for order confirmation emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@inshop-builder.com
