<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pc_contact_message_tree" model="ir.ui.view">
        <field name="name">pc.contact.message.tree</field>
        <field name="model">pc.contact.message</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'new'" decoration-muted="state == 'read'">
                <field name="create_date" string="Date"/>
                <field name="name"/>
                <field name="email"/>
                <field name="subject"/>
                <field name="state" widget="badge" decoration-info="state == 'new'" decoration-success="state == 'replied'"/>
            </tree>
        </field>
    </record>

    <record id="view_pc_contact_message_form" model="ir.ui.view">
        <field name="name">pc.contact.message.form</field>
        <field name="model">pc.contact.message</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" clickable="True"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="subject" placeholder="Sujet du message"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="email" widget="email"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Message">
                            <field name="message" placeholder="Contenu du message..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pc_contact_messages" model="ir.actions.act_window">
        <field name="name">Messages Contact</field>
        <field name="res_model">pc.contact.message</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun message reçu.
            </p>
            <p>
                Les messages envoyés depuis le formulaire de contact apparaîtront ici.
            </p>
        </field>
    </record>

    <menuitem id="menu_pc_contact_messages"
              name="Messages Contact"
              parent="menu_pc_builder_root"
              action="action_pc_contact_messages"
              sequence="50"/>
</odoo>
