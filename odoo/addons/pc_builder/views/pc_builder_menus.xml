<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Client Action : Dashboard OWL ───────────────────────────── -->
    <record id="action_pc_dashboard_client" model="ir.actions.client">
        <field name="name">Tableau de bord InShop</field>
        <field name="tag">pc_builder.dashboard</field>
    </record>

    <!-- ── Root Menu ────────────────────────────────────────────────── -->
    <menuitem id="menu_pc_builder_root"
              name="PC Builder"
              sequence="50"/>

    <!-- ── Tableau de bord ──────────────────────────────────────────── -->
    <menuitem id="menu_pc_dashboard"
              name="Tableau de bord"
              parent="menu_pc_builder_root"
              action="action_pc_dashboard_client"
              sequence="5"/>

    <!-- ── Commandes ────────────────────────────────────────────────── -->
    <menuitem id="menu_pc_orders"
              name="Commandes"
              parent="menu_pc_builder_root"
              action="action_pc_orders"
              sequence="15"/>

    <!-- ── Produits sub-menu ────────────────────────────────────────── -->
    <menuitem id="menu_pc_builder_products"
              name="Produits"
              parent="menu_pc_builder_root"
              sequence="20"/>

    <menuitem id="menu_pc_products"
              name="Composants &amp; Périphériques"
              parent="menu_pc_builder_products"
              action="action_pc_products"
              sequence="10"/>

    <menuitem id="menu_pc_prebuilts"
              name="PC Pré-montés"
              parent="menu_pc_builder_products"
              action="action_pc_prebuilts"
              sequence="20"/>

    <menuitem id="menu_pc_laptops"
              name="PC Portables"
              parent="menu_pc_builder_products"
              action="action_pc_laptops"
              sequence="25"/>

    <menuitem id="menu_pc_onlyonepc"
              name="Only One PC"
              parent="menu_pc_builder_products"
              action="action_pc_onlyonepc"
              sequence="30"/>

    <!-- ── Utilisateurs ─────────────────────────────────────────────── -->
    <menuitem id="menu_pc_users"
              name="Utilisateurs"
              parent="menu_pc_builder_root"
              action="action_pc_users"
              sequence="30"/>

</odoo>
