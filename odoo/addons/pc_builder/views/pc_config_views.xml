<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pc_config_form" model="ir.ui.view">
        <field name="name">pc.config.form</field>
        <field name="model">pc.config</field>
        <field name="arch" type="xml">
            <form string="Configuration INSHOP">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom du site"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Informations de Contact">
                            <field name="contact_email" widget="email"/>
                            <field name="contact_phone" widget="phone"/>
                            <field name="contact_address"/>
                            <field name="contact_opening_hours"/>
                        </group>
                        <group string="Réseaux Sociaux">
                            <field name="social_facebook" widget="url"/>
                            <field name="social_instagram" widget="url"/>
                            <field name="social_twitter" widget="url"/>
                            <field name="social_linkedin" widget="url"/>
                        </group>
                    </group>
                    <group string="Localisation sur la Carte">
                        <p class="text-muted" colspan="2" style="margin-bottom:8px;">
                            Renseignez les coordonnées GPS pour un positionnement précis sur la carte du site.
                            Si vide, la carte géocode automatiquement l'adresse ci-dessus.
                            Trouvez vos coordonnées sur <a href="https://www.openstreetmap.org" target="_blank">openstreetmap.org</a>
                            (clic droit → Afficher l'adresse).
                        </p>
                        <group>
                            <field name="map_lat" string="Latitude (ex: 14.7167)"/>
                            <field name="map_lng" string="Longitude (ex: -17.4677)"/>
                        </group>
                    </group>
                    <group string="Hero Banner (Accueil)">
                        <field name="hero_title"/>
                        <field name="hero_subtitle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pc_config_server" model="ir.actions.server">
        <field name="name">Configuration Site</field>
        <field name="model_id" ref="model_pc_config"/>
        <field name="state">code</field>
        <field name="code">
action = env['pc.config'].search([], limit=1)
if not action:
    action = env['pc.config'].create({'name': 'INSHOP BUILDER'})
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'pc.config',
    'view_mode': 'form',
    'res_id': action.id,
    'target': 'current',
}
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_pc_config"
              name="Configuration"
              parent="menu_pc_builder_root"
              action="action_pc_config_server"
              sequence="100"/>
</odoo>
