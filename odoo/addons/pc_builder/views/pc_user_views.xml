<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── User List View ────────────────────────────────────────────── -->
    <record id="view_pc_user_tree" model="ir.ui.view">
        <field name="name">pc.res.users.tree</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <tree string="Utilisateurs InShop" default_order="create_date desc">
                <field name="name" string="Nom"/>
                <field name="email" string="Email"/>
                <field name="phone" string="Téléphone"/>
                <field name="create_date" string="Inscription" widget="date"/>
                <field name="login_date" string="Dernière connexion" optional="show"/>
                <field name="active" string="Actif" widget="toggle_button"/>
            </tree>
        </field>
    </record>

    <!-- ── User Form View ────────────────────────────────────────────── -->
    <record id="view_pc_user_form" model="ir.ui.view">
        <field name="name">pc.res.users.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Utilisateur InShop">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Informations">
                            <field name="login" string="Email / Login"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group string="Statut">
                            <field name="active" string="Compte actif"/>
                            <field name="create_date" string="Inscrit le" readonly="1"/>
                            <field name="login_date" string="Dernière connexion" readonly="1"/>
                        </group>
                    </group>
                    <group string="Adresse">
                        <field name="street" string="Rue"/>
                        <field name="city" string="Ville"/>
                        <field name="zip" string="Code postal"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── User Search View ─────────────────────────────────────────── -->
    <record id="view_pc_user_search" model="ir.ui.view">
        <field name="name">pc.res.users.search</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <search string="Rechercher utilisateurs">
                <field name="name" string="Nom"/>
                <field name="email" string="Email"/>
                <separator/>
                <filter string="Actifs" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactifs" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Nouveaux ce mois" name="new_this_month"
                        domain="[('create_date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Mois d'inscription" name="group_month"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────── -->
    <record id="action_pc_users" model="ir.actions.act_window">
        <field name="name">Utilisateurs InShop</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <!-- Portail uniquement : share=True identifie les utilisateurs portail dans Odoo -->
        <field name="domain">[('share', '=', True)]</field>
        <field name="search_view_id" ref="view_pc_user_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun utilisateur inscrit pour l'instant.
            </p>
            <p>Les clients qui créent un compte sur le site InShop apparaîtront ici.</p>
        </field>
    </record>

</odoo>
