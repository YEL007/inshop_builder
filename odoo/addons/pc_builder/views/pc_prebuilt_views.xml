<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pc_prebuilt_tree" model="ir.ui.view">
        <field name="name">pc.prebuilt.tree</field>
        <field name="model">pc.prebuilt</field>
        <field name="arch" type="xml">
            <tree string="Pre-built PCs">
                <field name="name"/>
                <field name="tier"/>
                <field name="price"/>
                <field name="stock_status"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_pc_prebuilt_form" model="ir.ui.view">
        <field name="name">pc.prebuilt.form</field>
        <field name="model">pc.prebuilt</field>
        <field name="arch" type="xml">
            <form string="Pre-built PC">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="E.g. Gaming Alpha"/></h1>
                    </div>
                    <group>
                        <group string="Informations Générales">
                            <field name="price"/>
                            <field name="tier"/>
                            <field name="badge" placeholder="Gamer, Workstation..."/>
                            <field name="tag_line"/>
                            <field name="brand"/>
                        </group>
                        <group string="Statut &amp; Note">
                            <field name="stock_status"/>
                            <field name="rating"/>
                            <field name="review_count"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Composants (Affichage)">
                            <group>
                                <group>
                                    <field name="cpu"/>
                                    <field name="gpu"/>
                                    <field name="ram"/>
                                    <field name="storage"/>
                                </group>
                                <group>
                                    <field name="psu"/>
                                    <field name="case"/>
                                    <field name="cooling"/>
                                </group>
                            </group>
                        </page>
                        <page string="Données Techniques (Compatibilité &amp; Specs)">
                            <div class="alert alert-info" role="alert">
                                Ces champs permettent au système de vérifier la compatibilité et d'afficher les spécifications détaillées.
                            </div>
                            <group>
                                <group string="CPU &amp; RAM">
                                    <field name="tech_cpu_socket"/>
                                    <field name="tech_ram_type"/>
                                    <field name="tech_ram_capacity"/>
                                    <field name="tech_ram_speed"/>
                                </group>
                                <group string="Stockage &amp; GPU">
                                    <field name="tech_storage_type"/>
                                    <field name="tech_storage_capacity"/>
                                    <field name="tech_gpu_vram"/>
                                </group>
                                <group string="Alimentation">
                                    <field name="tech_psu_wattage"/>
                                    <field name="tech_psu_efficiency"/>
                                </group>
                            </group>
                            <group string="JSON résultant (Automatique)">
                                <field name="pc_specs" readonly="1" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Performance &amp; Photos">
                            <group>
                                <group string="Performance">
                                    <field name="gaming_perf"/>
                                    <field name="workflow"/>
                                </group>
                                <group string="Image Principale">
                                    <field name="image_1920" widget="image" options="{'size': [200, 200]}"/>
                                </group>
                            </group>
                            <group string="Images Supplémentaires">
                                <field name="extra_image_ids" nolabel="1">
                                    <kanban>
                                        <field name="id"/>
                                        <field name="name"/>
                                        <field name="image_1920"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click">
                                                    <div class="o_kanban_image">
                                                        <img t-att-src="kanban_image('pc.prebuilt.image', 'image_1920', record.id.raw_value)" alt="Product"/>
                                                    </div>
                                                    <div class="oe_kanban_details">
                                                        <field name="name"/>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                    <form string="Image">
                                        <group>
                                            <field name="name"/>
                                            <field name="image_1920" widget="image"/>
                                        </group>
                                    </form>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pc_prebuilts" model="ir.actions.act_window">
        <field name="name">Pre-built PCs</field>
        <field name="res_model">pc.prebuilt</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
