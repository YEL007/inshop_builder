<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Only One PC List View ──────────────────────────────────── -->
    <record id="view_pc_onlyonepc_tree" model="ir.ui.view">
        <field name="name">pc.onlyonepc.tree</field>
        <field name="model">pc.onlyonepc</field>
        <field name="arch" type="xml">
            <tree string="Only One PC">
                <field name="name"/>
                <field name="tier"/>
                <field name="price"/>
                <field name="badge"/>
                <field name="rating"/>
                <field name="review_count"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- ── Only One PC Form View ──────────────────────────────────── -->
    <record id="view_pc_onlyonepc_form" model="ir.ui.view">
        <field name="name">pc.onlyonepc.form</field>
        <field name="model">pc.onlyonepc</field>
        <field name="arch" type="xml">
            <form string="Only One PC">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Configuration name"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="tier" placeholder="Budget / Mid-Range / High-End / Flagship"/>
                            <field name="badge" placeholder="Best Seller"/>
                            <field name="tag_line" placeholder="Short marketing line"/>
                            <field name="brand" placeholder="Only One"/>
                            <field name="price"/>
                            <field name="stock_status"/>
                            <field name="active"/>
                        </group>
                        <group string="Ratings">
                            <field name="rating"/>
                            <field name="review_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Spécifications Techniques">
                            <group>
                                <group string="Composants principaux">
                                    <field name="cpu" placeholder="Intel Core i9-14900K"/>
                                    <field name="gpu" placeholder="NVIDIA RTX 4090"/>
                                    <field name="ram" placeholder="32GB DDR5-6000"/>
                                    <field name="storage" placeholder="2TB NVMe SSD"/>
                                </group>
                                <group string="Boîtier &amp; Alimentation">
                                    <field name="psu" placeholder="850W 80+ Gold"/>
                                    <field name="case" placeholder="Fractal Torrent"/>
                                    <field name="cooling" placeholder="360mm AIO"/>
                                </group>
                            </group>
                            <group string="Spécifications supplémentaires (JSON)">
                                <field name="pc_specs" nolabel="1"
                                       placeholder='{"pcie": "5.0", "wifi": "Wi-Fi 7", "bluetooth": "5.4", "usb_ports": 8}'/>
                            </group>
                        </page>
                        <page string="Use Cases">
                            <group>
                                <field name="gaming_perf" placeholder="1440p Ultra / 4K Gaming"/>
                                <field name="workflow" placeholder="Video editing &amp; streaming"/>
                            </group>
                        </page>
                        <page string="Images Supplémentaires">
                            <field name="extra_image_ids" context="{'default_name': name}">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="image_1920" widget="image" options="{'size': [90, 90]}"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Only One PC Search View ────────────────────────────────── -->
    <record id="view_pc_onlyonepc_search" model="ir.ui.view">
        <field name="name">pc.onlyonepc.search</field>
        <field name="model">pc.onlyonepc</field>
        <field name="arch" type="xml">
            <search string="Search Only One PC">
                <field name="name"/>
                <field name="tier"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Tier" name="group_tier" context="{'group_by': 'tier'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Only One PC Action ─────────────────────────────────────── -->
    <record id="action_pc_onlyonepc" model="ir.actions.act_window">
        <field name="name">Only One PC</field>
        <field name="res_model">pc.onlyonepc</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pc_onlyonepc_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre première configuration Only One PC
            </p>
            <p>Les configurations Only One PC apparaîtront dans la section dédiée du shop.</p>
        </field>
    </record>

</odoo>
