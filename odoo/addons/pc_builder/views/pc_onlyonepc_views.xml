<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pc_onlyonepc_tree" model="ir.ui.view">
        <field name="name">pc.onlyonepc.tree</field>
        <field name="model">pc.onlyonepc</field>
        <field name="arch" type="xml">
            <tree string="Only One PCs">
                <field name="name"/>
                <field name="badge"/>
                <field name="price"/>
                <field name="stock_status"/>
            </tree>
        </field>
    </record>

    <record id="view_pc_onlyonepc_form" model="ir.ui.view">
        <field name="name">pc.onlyonepc.form</field>
        <field name="model">pc.onlyonepc</field>
        <field name="arch" type="xml">
            <form string="Only One PC">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="E.g. Creator Beast"/></h1>
                    </div>
                    <group>
                        <group string="Informations">
                            <field name="price"/>
                            <field name="badge"/>
                            <field name="tag_line"/>
                        </group>
                        <group string="Statut">
                            <field name="stock_status"/>
                            <field name="rating"/>
                            <field name="review_count"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Configuration">
                            <group>
                                <group string="Composants (Affichage)">
                                    <field name="cpu"/>
                                    <field name="gpu"/>
                                    <field name="ram"/>
                                    <field name="storage"/>
                                    <field name="psu"/>
                                    <field name="case"/>
                                    <field name="cooling"/>
                                </group>
                                <group string="Données Techniques (Spécifications)">
                                    <field name="tech_cpu_socket"/>
                                    <field name="tech_ram_type"/>
                                    <field name="tech_ram_capacity"/>
                                    <field name="tech_ram_speed"/>
                                    <field name="tech_storage_type"/>
                                    <field name="tech_storage_capacity"/>
                                    <field name="tech_gpu_vram"/>
                                    <field name="tech_psu_wattage"/>
                                    <field name="tech_psu_efficiency"/>
                                </group>
                            </group>
                        </page>
                        <page string="Apparence &amp; Photos">
                            <group>
                                <group string="Image Principale">
                                    <field name="image_1920" widget="image" options="{'size': [200, 200]}"/>
                                </group>
                            </group>
                            <group string="Images Supplémentaires">
                                <field name="extra_image_ids" nolabel="1">
                                    <kanban>
                                        <field name="id"/>
                                        <field name="name"/>
                                        <field name="image_1920"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click">
                                                    <div class="o_kanban_image">
                                                        <img t-att-src="kanban_image('pc.onlyonepc.image', 'image_1920', record.id.raw_value)" alt="Product"/>
                                                    </div>
                                                    <div class="oe_kanban_details">
                                                        <field name="name"/>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                    <form string="Image">
                                        <group>
                                            <field name="name"/>
                                            <field name="image_1920" widget="image"/>
                                        </group>
                                    </form>
                                </field>
                            </group>
                        </page>
                        <page string="JSON (Auto)" groups="base.group_no_one">
                            <field name="pc_specs" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pc_onlyonepc" model="ir.actions.act_window">
        <field name="name">Only One PCs</field>
        <field name="res_model">pc.onlyonepc</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
